# zoho-api.yaml — OAuth credentials for Zoho Creator API
# Copy this to zoho-api.yaml and fill in your credentials
# NEVER commit zoho-api.yaml to git

auth:
  client_id: "YOUR_CLIENT_ID"
  client_secret: "YOUR_CLIENT_SECRET"
  refresh_token: "YOUR_REFRESH_TOKEN"
  token_url: "https://accounts.zoho.com/oauth/v2/token"

api:
  base_url: "https://creator.zoho.com/api/v2.1"
  owner: "your_zoho_username"
  app: "ten-chargeback-management"
