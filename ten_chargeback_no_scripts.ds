	reports
	{
		list chargeback_incidents_Report
		{
			displayName = "All Chargeback Incidents"
			show all rows from chargeback_incidents    
			(
				incident_id as "Incident ID"
				psp_reference as "PSP Reference"
				platform as "Platform"
				merchant_account as "Merchant Account"
				incident_date as "Incident Date"
				amount_original as "Amount Original"
				(
					display = total,average,min,max	
				)
				amount_usd as "Amount USD"
				(
					display = total,average,min,max	
				)
				currency_original as "Currency Original"
				status as "Status"
				assigned_lm as "Assigned LM"
				days_remaining as "Days Remaining"
				customer as "Customer"
				invoice as "Invoice"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Disputed")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Expired")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "Open")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban chargeback_incidents_by_status
		{
			displayName = "Statuses"
			show all rows from chargeback_incidents    
			(
				incident_id as "Incident ID"
				psp_reference as "PSP Reference"
				platform as "Platform"
				merchant_account as "Merchant Account"
				incident_date as "Incident Date"
				amount_original as "Amount Original"
				(
					display = total,average,min,max	
				)
				amount_usd as "Amount USD"
				(
					display = total,average,min,max	
				)
				currency_original as "Currency Original"
				status as "Status"
				assigned_lm as "Assigned LM"
				days_remaining as "Days Remaining"
				customer as "Customer"
				invoice as "Invoice"
			)
			options
			(
	 			display field = status
	 		)
		}
