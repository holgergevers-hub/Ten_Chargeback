		list regional_config_Report
		{
			displayName = "All Regional Config"
			show all rows from regional_config    
			(
				merchant_account as "merchant_account"
				region as "region"
				default_currency as "default_currency"
				default_lm_name as "default_lm_name"
				default_lm_email as "default_lm_email"
			)
		}
		list dispute_reason_codes_Report
		{
			displayName = "All Dispute Reason Codes"
			show all rows from dispute_reason_codes    
			(
				scheme as "scheme"
				code as "code"
				description as "description"
				category as "category"
			)
		}
		list dispute_submissions_Report
		{
			displayName = "All Disputes"
			show all rows from dispute_submissions    
			(
				incident as "incident"
				submission_date as "submission_date"
				submitted_by as "submitted_by"
				dispute_reason_text as "dispute_reason_text"
				expected_response_date as "expected_response_date"
			)
		}
		list file_uploads_Report
		{
			displayName = "All File Uploads"
			show all rows from file_uploads    
			(
				file_name as "file_name"
				platform_name as "platform_name"
				processing_status as "processing_status"
				records_found as "records_found"
				records_imported as "records_imported"
			)
		}
		list Open_Chargebacks
		{
			displayName = "All Open Chargebacks"
			show all rows from chargeback_incidents  [status == "Open" || status == "Under Review"]  
			(
				psp_reference as "psp_reference"
				platform as "platform"
				merchant_account as "merchant_account"
				amount_usd as "amount_usd"
				incident_date as "incident_date"
				days_remaining as "days_remaining"
				assigned_lm as "assigned_lm"
			)
		}
		list Expiring_Soon
		{
			displayName = "All Expiring Soon"
			show all rows from chargeback_incidents  [days_remaining <= 5 && days_remaining > 0 && (status == "Open" || status == "Under Review")]  
			(
				psp_reference as "psp_reference"
				platform as "platform"
				amount_usd as "amount_usd"
				days_remaining as "days_remaining"
				assigned_lm as "assigned_lm"
				Dispute_Deadline as "Dispute_Deadline"
			)
		}
	}
	pages
	{
		page DashBoard
		{
			displayname = "Dashboard"
