 application "Chargeback Management System"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"

 	forms
	{
		form audit_trail
		{
			displayname = "Audit Trail"
			success message = "Audit Trail Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			incident_id
			(
				type = list	
				displayname = "Incident ID"
				values  = chargeback_incidents.ID
    			displayformat = [incident_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			action_1
			(
    			type = text
				displayname = "Action"
	 			row = 1
	 			column = 1   
				width = medium
			)
			action_date
			(
    			type = datetime
				displayname = "Action Date"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			performed_by
			(
    			type = text
				displayname = "Performed By"
	 			row = 1
	 			column = 1   
				width = medium
			)
			notes
			(
    			type = textarea
				displayname = "Notes"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Audit Trail Created","Audit Review Initiated","Audit Trail Pending Approval","Review Completed","Audit Review In Progress","Audit Trail Rejected","Audit Review Reopened","Audit Trail Approved","Audit Trail Pending Re-Review","Adjustment Processed","Audit Trail Archived","Audit Trail Resubmitted","Audit Trail Closed","Audit Trail Reopened"}
			}
		}
