			"Chargeback Analyst"
			{
				name = "Chargeback Analyst"
				type = Users_Permissions
				permissions = {Chat:false, Predefined:false, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "Investigate and document chargeback incidents using PSP references and incident details \n"
