				avatax_exemption_number as "Avatax Exemption Number"
				avatax_tax_code as "Avatax Tax Code"
				avatax_use_code as "Avatax Use Code"
				balance as "Balance"
				cfdi_reference_type as "CFDI Reference Type"
				cfdi_usage as "CFDI Usage"
				client_viewed_time as "Client Viewed Time"
				created_time as "Created Time"
				credits_applied as "Credits Applied"
				custom_body as "Custom Body"
				custom_subject as "Custom Subject"
				customer_notes as "Customer Notes"
				discount as "Discount"
				due_date as "Due Date"
				exchange_rate as "Exchange Rate"
				gst_number as "GST Number"
				invoice_date as "Invoice Date"
				invoice_description as "Invoice Description"
				invoice_number as "Invoice Number"
				last_modified_time as "Last Modified Time"
				last_payment_date as "Last Payment Date"
				last_reminder_sent_date as "Last Reminder Sent Date"
				order_number as "Order Number"
				payment_expected_date as "Payment Expected Date"
				payment_made as "Payment Made"
				price_precision as "Price Precision"
				reason as "Reason"
				reminders_sent as "Reminders Sent"
				shipping_charge as "Shipping Charge"
				subject_field as "Subject"
				subtotal as "Subtotal"
				tax_amount_withheld as "Tax Amount Withheld"
				tax_total as "Tax Total"
